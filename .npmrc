# All JH packages are vendored in vendor/ — no Artifactory token needed to run npm install.
# The registry entries below are only needed by the maintainer when updating package versions.
#
# Maintainer setup (one-time):
# 1. Get your Identity Token from https://jackhenry.jfrog.io/ui/user_profile
# 2. Store in Keychain: security add-generic-password -a "$USER" -s "ARTIFACTORY_TOKEN" -w <token>
# 3. Add to ~/.zshrc: export ARTIFACTORY_TOKEN=$(security find-generic-password -a "$USER" -s "ARTIFACTORY_TOKEN" -w)

legacy-peer-deps=true

@banno:registry=https://artifactory.banno-tools.com/artifactory/api/npm/npm/
@jkhy:registry=https://artifactory.banno-tools.com/artifactory/api/npm/npm/
@jack-henry:registry=https://artifactory.banno-tools.com/artifactory/api/npm/npm/
@jackhenry:registry=https://artifactory.banno-tools.com/artifactory/api/npm/npm/
//artifactory.banno-tools.com/artifactory/api/npm/npm/:_authToken=${ARTIFACTORY_TOKEN}
