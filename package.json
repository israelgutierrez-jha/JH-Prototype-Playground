{
  "name": "jh-prototype-playground",
  "version": "0.1.0",
  "description": "JH design team prototype playground — build interactive prototypes with JH components + Claude Code",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -noEmit && vite build",
    "preview": "vite preview",
    "generate-docs": "tsx scripts/generate-component-docs.ts",
    "check-docs": "tsx scripts/generate-component-docs.ts --check",
    "sync-rules": "node scripts/sync-rules.js",
    "docs": "npm run generate-docs && npm run sync-rules",
    "postinstall": "node scripts/sync-rules.js"
  },
  "dependencies": {
    "@banno/jha-wc": "file:./vendor/banno-jha-wc-13.20.1.tgz",
    "@jack-henry/jh-datasets": "file:./vendor/jack-henry-jh-datasets-2.0.0-beta.1.tgz",
    "@jack-henry/jh-elements": "file:./vendor/jack-henry-jh-elements-2.0.0-beta.14.tgz",
    "@jack-henry/jh-icons": "file:./vendor/jack-henry-jh-icons-2.0.0-beta.8.tgz",
    "@jack-henry/jh-tokens": "file:./vendor/jack-henry-jh-tokens-2.0.0-beta.9.tgz",
    "@jack-henry/web-component-router": "file:./vendor/jack-henry-web-component-router-3.12.2.tgz",
    "@jkhy/frontend-utils": "file:./vendor/jkhy-frontend-utils-3.14.1.tgz",
    "@jkhy/platform-tools": "file:./vendor/jkhy-platform-tools-2.0.0.tgz",
    "@lit/context": "^1.1.6",
    "lit": "3.3.1"
  },
  "devDependencies": {
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
